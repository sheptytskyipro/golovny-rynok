# ============================================================
# Головний Ринок — змінні середовища БЕКЕНДУ
# Скопіюй цей файл у server/.env і заповни реальними значеннями
# УВАГА: .env ніколи не потрапляє в репозиторій!
# ============================================================

# Порт сервера (Railway задає автоматично)
PORT=3001

# Telegram Bot Token
# Отримати: у Telegram знайди @BotFather → /newbot → скопіюй токен
# Формат: 1234567890:ABCdefGHIjklMNOpqrSTUVwxyz
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Примітка: у коді бекенду змінна називається BOT_TOKEN
BOT_TOKEN=your_bot_token_here

# LiqPay ключі (ОБИДВА тільки на бекенді!)
# Отримати: https://www.liqpay.ua → Бізнес → API → Ключі
# Sandbox-ключі для тестування: https://www.liqpay.ua/en/doc/sandbox
LIQPAY_PUBLIC_KEY=sandbox_your_public_key_here
LIQPAY_PRIVATE_KEY=sandbox_your_private_key_here

# Нова Пошта API ключ (дублюємо на бекенді для серверних запитів)
# Отримати: https://new.novaposhta.ua → Налаштування → Безпека → Згенерувати API-ключ
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key_here

# PostgreSQL рядок підключення
# Безкоштовно: https://neon.tech або https://supabase.com
# Neon: Projects → Connection Details → Connection string
# Формат: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/golovny_rynok

# URL фронтенду (для CORS і LiqPay result_url)
# Локально: http://localhost:5173
# Продакшн: https://твій-домен.railway.app
FRONTEND_URL=http://localhost:5173

# Середовище (development / production)
NODE_ENV=development
