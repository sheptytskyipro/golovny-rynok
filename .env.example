# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# LiqPay Payment Gateway
LIQPAY_PUBLIC_KEY=your_liqpay_public_key
LIQPAY_PRIVATE_KEY=your_liqpay_private_key

# Nova Poshta Delivery
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/golovny_rynok

# App URLs
FRONTEND_URL=https://your-app.netlify.app
PORT=3001
NODE_ENV=development

# Frontend env vars (prefix with VITE_)
VITE_NOVA_POSHTA_API_KEY=your_nova_poshta_api_key
VITE_API_URL=http://localhost:3001
