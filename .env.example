# ============================================================
# Головний Ринок — змінні середовища ФРОНТЕНДУ
# Скопіюй цей файл у .env і заповни реальними значеннями
# УВАГА: .env ніколи не потрапляє в репозиторій!
# ============================================================

# URL бекенд-API (для локальної розробки — localhost, для продакшну — твій Railway/Render URL)
VITE_API_URL=http://localhost:3001

# API-ключ Нова Пошта (публічний — безпечно на фронті)
# Отримати: https://new.novaposhta.ua → Налаштування → Безпека → Згенерувати API-ключ
VITE_NOVA_POSHTA_API_KEY=your_nova_poshta_api_key_here

# LiqPay ПУБЛІЧНИЙ ключ (не приватний — тільки публічний на фронті)
# Отримати: https://www.liqpay.ua → Бізнес → API → Ключі
VITE_LIQPAY_PUBLIC_KEY=sandbox_your_public_key_here
